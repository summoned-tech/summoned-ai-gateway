NODE_ENV=local
GATEWAY_PORT=4200

# =============================================================================
# AUTH & PUBLIC MODE
# =============================================================================

# Set to "false" to allow unauthenticated requests (public / self-hosted mode).
# In that mode callers MUST supply their own provider API key via the
# "x-provider-key" header (BYOK — Bring Your Own Key).
# Default: "true" (requires a summoned sk-smnd-... API key on every request).
GATEWAY_REQUIRE_AUTH=true

# Requests per minute cap applied per source IP for BYOK / unauthenticated callers.
PUBLIC_RPM_LIMIT=60

# =============================================================================
# ADMIN
# =============================================================================

# Master admin key — used to create/revoke tenant API keys via POST /v1/keys
# Generate: openssl rand -hex 32
# If left unset in local/development mode the gateway auto-generates an
# ephemeral key on boot and prints it to stdout. For production/staging this
# MUST be set explicitly (otherwise startup fails).
ADMIN_API_KEY=

# Encryption key for stored provider credentials (virtual keys).
# Must be a different secret from ADMIN_API_KEY.
# Generate: openssl rand -hex 32
# If unset, ADMIN_API_KEY is used as fallback (not recommended for production).
VIRTUAL_KEY_SECRET=

# Encryption key for virtual keys (AES-256). Must be 32 bytes hex-encoded.
# Generate: openssl rand -hex 32
# VIRTUAL_KEY_SECRET=

# =============================================================================
# LLM PROVIDERS — set the keys for providers you want to enable.
# Only providers with valid credentials are registered at startup.
# You need at least ONE provider to serve requests.
# =============================================================================

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Azure OpenAI — https://portal.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# AWS Bedrock — IAM credentials with bedrock:InvokeModel permission
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BEDROCK_API_KEY=
# Set to "true" when running on EC2/ECS/EKS with an IAM instance profile.
# Bedrock will register without explicit keys and use the default AWS SDK
# credential chain (instance role > env > shared profile).
AWS_USE_INSTANCE_PROFILE=false
# Demo mode: routes all tiers to Nova Lite (cheap, for dev/testing)
BEDROCK_DEMO_MODE=false

# Ollama — local inference (no key needed, just the URL)
# Install: https://ollama.com → then: ollama serve
OLLAMA_BASE_URL=

# Sarvam AI — India-first multilingual models (https://www.sarvam.ai)
SARVAM_API_KEY=

# Yotta Labs — Indian GPU cloud
YOTTA_API_KEY=

# Mistral AI — https://console.mistral.ai
MISTRAL_API_KEY=

# Together AI — https://api.together.xyz
TOGETHER_API_KEY=

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Fireworks AI — https://fireworks.ai
FIREWORKS_API_KEY=

# Cohere — https://dashboard.cohere.com
COHERE_API_KEY=

# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# xAI / Grok — https://console.x.ai
XAI_API_KEY=

# Custom OpenAI-compatible providers (JSON array)
# Example: [{"id":"myprovider","name":"My LLM","baseUrl":"https://api.example.com/v1","apiKey":"sk-..."}]
CUSTOM_PROVIDERS=

# =============================================================================
# INFRASTRUCTURE  (both optional — gateway runs stateless without them)
# =============================================================================

# PostgreSQL — stores API keys, virtual keys, and request audit logs
# Leave blank to run in stateless mode (no request history, no managed keys)
POSTGRES_URL=

# Redis — rate limiting, response caching, latency EMA
# Leave blank to use in-memory fallbacks (single-instance, resets on restart)
REDIS_URL=

# =============================================================================
# OBSERVABILITY (optional)
# =============================================================================

# OpenTelemetry — send traces to Jaeger, Grafana Tempo, etc.
# Leave empty to disable remote trace export
OTEL_EXPORTER_OTLP_ENDPOINT=

# Cost tracking — USD to INR conversion rate
USD_INR_RATE=85
