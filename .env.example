NODE_ENV=local
GATEWAY_PORT=4000

# Admin key — used to create/revoke tenant API keys via POST /v1/keys
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your-admin-secret-min-32-chars-here

# AWS Bedrock — ap-south-1 (Mumbai) for DPDP compliance
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: Bedrock-specific API key (takes precedence over IAM credentials)
AWS_BEDROCK_API_KEY=

# Demo mode: routes all model tiers to Nova Lite (cheap, for dev/testing)
BEDROCK_DEMO_MODE=true

# PostgreSQL — stores API keys and request audit logs
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/summoned_gateway

# Redis — rate limiting and key cache
REDIS_URL=redis://localhost:6379

# OpenTelemetry — optional, leave empty to disable remote trace export
OTEL_EXPORTER_OTLP_ENDPOINT=
