{
  "name": "summoned-gateway",
  "version": "0.1.0",
  "description": "Summoned AI Gateway — sovereign AI infrastructure for India",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outfile dist/index.mjs --target bun --minify",
    "start": "bun dist/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.89",
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.61",
    "@ai-sdk/openai": "^3.0.52",
    "@aws-sdk/client-bedrock": "^3.750.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.57.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/instrumentation-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-metrics": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "ai": "^6.0.145",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.7",
    "pino": "^9.6.0",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2"
  }
}
